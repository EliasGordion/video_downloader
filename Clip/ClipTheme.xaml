<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="ClipAppBackgroundBrush" Color="#F6F7FB" />
            <SolidColorBrush x:Key="ClipCardBackgroundBrush" Color="#FCFCFE" />
            <SolidColorBrush x:Key="ClipCardBorderBrush" Color="#0F000000" />
            <SolidColorBrush x:Key="ClipMutedSurfaceBrush" Color="#F0F2F7" />
            <SolidColorBrush x:Key="ClipSubtleTextBrush" Color="#667085" />
            <SolidColorBrush x:Key="ClipImageOutlineBrush" Color="#1A000000" />
            <SolidColorBrush x:Key="ClipAccentSoftBrush" Color="#167C6CF2" />
            <SolidColorBrush x:Key="ClipLavenderBrush" Color="#7C6CF2" />
            <SolidColorBrush x:Key="ClipRosewoodBrush" Color="#D94F70" />
            <SolidColorBrush x:Key="ClipCoralBrush" Color="#F45E55" />
            <SolidColorBrush x:Key="ClipBronzeBrush" Color="#C47B24" />
            <SolidColorBrush x:Key="ClipSuccessBrush" Color="#1F9D63" />
            <SolidColorBrush x:Key="ClipDangerBrush" Color="#C73E56" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="ClipAppBackgroundBrush" Color="#121419" />
            <SolidColorBrush x:Key="ClipCardBackgroundBrush" Color="#1B1E25" />
            <SolidColorBrush x:Key="ClipCardBorderBrush" Color="#16FFFFFF" />
            <SolidColorBrush x:Key="ClipMutedSurfaceBrush" Color="#252933" />
            <SolidColorBrush x:Key="ClipSubtleTextBrush" Color="#AAB1BF" />
            <SolidColorBrush x:Key="ClipImageOutlineBrush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="ClipAccentSoftBrush" Color="#26A799FF" />
            <SolidColorBrush x:Key="ClipLavenderBrush" Color="#A799FF" />
            <SolidColorBrush x:Key="ClipRosewoodBrush" Color="#EA7893" />
            <SolidColorBrush x:Key="ClipCoralBrush" Color="#FF7D74" />
            <SolidColorBrush x:Key="ClipBronzeBrush" Color="#D69B45" />
            <SolidColorBrush x:Key="ClipSuccessBrush" Color="#41C982" />
            <SolidColorBrush x:Key="ClipDangerBrush" Color="#FF8A9D" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="ClipCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ClipCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ClipCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="ClipSmallCardStyle" TargetType="Border" BasedOn="{StaticResource ClipCardStyle}">
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="PillButtonStyle" TargetType="Button">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="15,9" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="QuietPillButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource ClipMutedSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource ClipCardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AccentPillButtonStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
        <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource QuietPillButtonStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="DangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Foreground" Value="{ThemeResource ClipDangerBrush}" />
    </Style>

    <Style x:Key="ChoiceListItemStyle" TargetType="ListViewItem">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Width" Value="58" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="0,0,6,8" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="LanguageChoiceListItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource ChoiceListItemStyle}">
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Width" Value="150" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="FlatListItemStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource ClipSubtleTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="EyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{ThemeResource ClipSubtleTextBrush}" />
    </Style>

    <Style x:Key="NumericalTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="Typography.NumeralAlignment" Value="Tabular" />
    </Style>

    <Style x:Key="DangerCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
        <Setter Property="Foreground" Value="{ThemeResource ClipDangerBrush}" />
    </Style>

    <Style x:Key="BadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ClipMutedSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,5" />
    </Style>
</ResourceDictionary>
