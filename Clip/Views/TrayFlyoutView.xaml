<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clip.Views.TrayFlyoutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource ClipCardStyle}" Width="320">
        <StackPanel Spacing="10">
            <TextBlock Text="Clip" Style="{StaticResource SectionTitleTextStyle}" />
            <TextBox PlaceholderText="{Binding Text.PasteVideoUrlPlaceholder, FallbackValue=Paste URL}" />
            <Button Style="{StaticResource AccentPillButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8EF;" FontSize="14" />
                    <TextBlock Text="{Binding Text.AnalyzeAction, FallbackValue=Analyze}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
