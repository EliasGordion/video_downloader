<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clip.Views.ContentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Clip.Views">
    <Grid Background="{ThemeResource ClipAppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="28,22,28,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border
                    Width="44"
                    Height="44"
                    CornerRadius="13"
                    Background="{ThemeResource ClipAccentSoftBrush}">
                    <FontIcon
                        Glyph="&#xE8B5;"
                        FontSize="20"
                        Foreground="{ThemeResource ClipLavenderBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Clip" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="{x:Bind Main.StatusMessage, Mode=OneWay}" Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>
            </StackPanel>
            <views:StatusBarView
                Grid.Column="1"
                VerticalAlignment="Center"
                DataContext="{x:Bind Downloads, Mode=OneWay}" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="28,0,28,32" BringIntoViewOnFocusChange="False">
            <StackPanel MaxWidth="1120" Spacing="16" HorizontalAlignment="Center">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromVerticalOffset="12" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
                <views:UpdateBannerView DataContext="{x:Bind Settings, Mode=OneWay}" />
                <views:URLInputView DataContext="{x:Bind Main, Mode=OneWay}" />
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="16">
                        <views:VideoPreviewView DataContext="{x:Bind Main, Mode=OneWay}" />
                        <views:ClipRangeView DataContext="{x:Bind Main, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="16">
                        <views:FormatPickerView DataContext="{x:Bind Main, Mode=OneWay}" />
                        <views:SaveLocationView DataContext="{x:Bind Settings, Mode=OneWay}" />
                        <views:DownloadSectionView DataContext="{x:Bind Downloads, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <TabView IsAddTabButtonVisible="False" MinHeight="320" DataContext="{x:Bind Settings, Mode=OneWay}">
                    <TabViewItem Header="{Binding Text.DownloadsTab}" IsClosable="False">
                        <views:DownloadListView DataContext="{x:Bind Downloads, Mode=OneWay}" />
                    </TabViewItem>
                    <TabViewItem Header="{Binding Text.HistoryTab}" IsClosable="False">
                        <views:HistoryView DataContext="{x:Bind Downloads, Mode=OneWay}" />
                    </TabViewItem>
                    <TabViewItem Header="{Binding Text.SettingsTab}" IsClosable="False">
                        <views:SettingsView DataContext="{x:Bind Settings, Mode=OneWay}" />
                    </TabViewItem>
                </TabView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
