<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clip.Views.StatusBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource BadgeBorderStyle}" Padding="12,7">
        <StackPanel Orientation="Horizontal" Spacing="7">
            <Ellipse Width="7" Height="7" Fill="{ThemeResource ClipSuccessBrush}" />
            <TextBlock Text="{Binding QueueSummary}" Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>
    </Border>
</UserControl>
