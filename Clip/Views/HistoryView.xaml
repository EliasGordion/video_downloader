<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clip.Views.HistoryView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="260">
        <StackPanel
            Visibility="{Binding HasHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">
            <Border
                Width="52"
                Height="52"
                CornerRadius="16"
                Background="{ThemeResource ClipMutedSurfaceBrush}"
                HorizontalAlignment="Center">
                <FontIcon
                    Glyph="&#xE81C;"
                    FontSize="22"
                    Foreground="{ThemeResource ClipSubtleTextBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Text.HistoryEmptyTitle}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding Text.HistoryEmptyDescription}"
                Style="{StaticResource CaptionTextStyle}"
                TextAlignment="Center" />
        </StackPanel>

        <ListView
            Visibility="{Binding HasHistory, Converter={StaticResource BooleanToVisibilityConverter}}"
            ItemsSource="{Binding History}"
            SelectionMode="None"
            ItemContainerStyle="{StaticResource FlatListItemStyle}"
            Padding="0,10,0,0">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="8" IsStaggeringEnabled="True" />
                    <AddDeleteThemeTransition />
                    <RepositionThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ClipSmallCardStyle}" Margin="0,0,0,12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="5">
                                <TextBlock
                                    Text="{Binding Title}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    TextWrapping="Wrap"
                                    MaxLines="2" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding FormatSummary}" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="·" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Text="{Binding CompletedAtText}" Style="{StaticResource NumericalTextStyle}" />
                                </StackPanel>
                                <TextBlock
                                    Text="{Binding OutputPath}"
                                    Style="{StaticResource CaptionTextStyle}"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFileClick" IsEnabled="{Binding CanOpenFile}" ToolTipService.ToolTip="{Binding DataContext.Text.OpenFileTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="13" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFolderClick" ToolTipService.ToolTip="{Binding DataContext.Text.OpenFolderTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="13" />
                                </Button>
                                <Button Style="{StaticResource DangerIconButtonStyle}" Click="OnRemoveFromHistoryClick" ToolTipService.ToolTip="{Binding DataContext.Text.RemoveFromHistoryTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE711;" FontSize="13" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
