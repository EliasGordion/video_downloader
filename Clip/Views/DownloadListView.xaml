<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clip.Views.DownloadListView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="260">
        <StackPanel
            Visibility="{Binding HasDownloads, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">
            <Border
                Width="52"
                Height="52"
                CornerRadius="16"
                Background="{ThemeResource ClipAccentSoftBrush}"
                HorizontalAlignment="Center">
                <FontIcon
                    Glyph="&#xE896;"
                    FontSize="22"
                    Foreground="{ThemeResource ClipLavenderBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Text.NoDownloadsTitle}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock
                Text="{Binding Text.NoDownloadsDescription}"
                Style="{StaticResource CaptionTextStyle}"
                TextAlignment="Center" />
        </StackPanel>

        <ListView
            Visibility="{Binding HasDownloads, Converter={StaticResource BooleanToVisibilityConverter}}"
            ItemsSource="{Binding Downloads}"
            SelectionMode="None"
            ItemContainerStyle="{StaticResource FlatListItemStyle}"
            Padding="0,10,0,0">
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="8" IsStaggeringEnabled="True" />
                    <RepositionThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ClipSmallCardStyle}" Margin="0,0,0,12">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        Text="{Binding Title}"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        TextWrapping="Wrap"
                                        MaxLines="2" />
                                    <TextBlock Text="{Binding FormatSummary}" Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeBorderStyle}" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding StatusDisplay}" Style="{StaticResource CaptionTextStyle}" />
                                </Border>
                            </Grid>
                            <StackPanel Spacing="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DataContext.Text.ProgressLabel, ElementName=Root}" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}" Style="{StaticResource NumericalTextStyle}" />
                                </Grid>
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="6" CornerRadius="3" />
                            </StackPanel>
                            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource DangerCaptionTextStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnCancelClick" IsEnabled="{Binding CanCancel}" ToolTipService.ToolTip="{Binding DataContext.Text.CancelTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE711;" FontSize="13" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnRetryClick" IsEnabled="{Binding CanRetry}" ToolTipService.ToolTip="{Binding DataContext.Text.RetryTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFileClick" IsEnabled="{Binding CanOpenFile}" ToolTipService.ToolTip="{Binding DataContext.Text.OpenFileTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="13" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFolderClick" ToolTipService.ToolTip="{Binding DataContext.Text.OpenFolderTooltip, ElementName=Root}">
                                    <FontIcon Glyph="&#xE8B7;" FontSize="13" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
